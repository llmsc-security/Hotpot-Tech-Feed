# Copy this to .env and fill in real values. Never commit .env.

# ----- Core -----
ENV=dev
LOG_LEVEL=INFO

# ----- Postgres -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hotpot
POSTGRES_USER=hotpot
POSTGRES_PASSWORD=hotpot

# ----- Redis / Celery -----
REDIS_URL=redis://localhost:6379/0

# ----- Qdrant -----
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=hotpot_items

# ----- LLM (Qwen via OpenAI-compatible endpoint) -----
OPENAI_BASE_URL=https://api.ai2wj.com/v1
OPENAI_API_KEY=replace_me
LLM_MODEL_TAGGER=qwen3.6
LLM_MODEL_SUMMARY=qwen3.6
LLM_MODEL_COMMENTARY=qwen3.6

# ----- Embeddings (bge-m3 local) -----
# Flip to true once you've installed the [embeddings] extra and downloaded weights.
EMBEDDINGS_ENABLED=false
EMBEDDINGS_MODEL=BAAI/bge-m3
EMBEDDINGS_DIM=1024

# ----- Email (Resend via send.ai2wj.com) -----
# Domain ai2wj.com is verified at Resend with the send.ai2wj.com subdomain
# carrying the SPF / DKIM / return-path. Set SMTP_PASSWORD to your Resend API key.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USE_TLS=true
SMTP_USERNAME=resend
SMTP_PASSWORD=re_replace_me
DIGEST_FROM_EMAIL=digest@ai2wj.com
DIGEST_FROM_NAME=Hotpot Tech Feed
DIGEST_REPLY_TO=noreply@ai2wj.com

# ----- Crawler -----
USER_AGENT="HotpotTechFeed/0.1 (+https://feed.ai2wj.com; contact: jornbowrl@gmail.com)"
HTTP_TIMEOUT_S=20

# ----- Pipeline knobs -----
DEDUP_TITLE_THRESHOLD=0.90
DEDUP_EMBEDDING_THRESHOLD=0.92
DEDUP_WINDOW_DAYS=7
ENRICH_SUMMARY=true
ENRICH_COMMENTARY=false

# ----- Site -----
PUBLIC_ORIGIN=http://localhost:5173
