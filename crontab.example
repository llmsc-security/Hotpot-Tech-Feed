# Hotpot Tech Feed — host crontab.
#
# Install on the host that runs the docker stack:
#   crontab -e
#   <paste the lines below, replacing the path>
#   crontab -l                       # verify
#
# These run on YOUR machine, against YOUR docker stack. They cannot be moved
# to the cloud `/schedule` routine because that one has no DB access.

ROOT=/data/wangjian/wj_code/dl_feed/Hotpot-Tech-Feed
LOG=/data/wangjian/wj_code/dl_feed/Hotpot-Tech-Feed/logs
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Make logs dir after installing:
#   mkdir -p /data/wangjian/wj_code/dl_feed/Hotpot-Tech-Feed/logs

# Hourly: poll HTML index/sitemap sources. This is the RSS-like path for sites
# without feeds; canonical URL dedup turns repeated polling into "new only".
10 * * * *   $ROOT/scripts/cron_hotpot.sh ingest-html >> $LOG/ingest-html.log 2>&1

# Every 2 hours: pull RSS/Atom sources.
20 */2 * * * $ROOT/scripts/cron_hotpot.sh ingest-rss >> $LOG/ingest-rss.log 2>&1

# Every 6 hours: pull arXiv categories.
0 */6 * * *  $ROOT/scripts/cron_hotpot.sh ingest-arxiv >> $LOG/ingest-arxiv.log 2>&1

# Daily full pass as a backstop across all active sources.
0 2 * * *    WORKERS=8 SOURCE_WORKERS=1 $ROOT/scripts/cron_hotpot.sh ingest-now >> $LOG/ingest-full.log 2>&1

# Every 30 minutes: fast pass over only-empty sources (catches just-promoted
# candidates that the API's auto-ingest may have missed).
30 * * * *   $ROOT/scripts/cron_hotpot.sh ingest-empty >> $LOG/ingest-empty.log 2>&1

# Hourly: source health check (HEAD each URL, mark broken).
15 * * * *   $ROOT/scripts/cron_hotpot.sh health-check-sources >> $LOG/health.log 2>&1

# Daily 03:00 UTC: re-score sources from click data + LLM noise sample.
0 3 * * *    $ROOT/scripts/cron_hotpot.sh score-sources >> $LOG/score.log 2>&1

# Daily 03:10 UTC: refresh the dedicated /security score projection.
10 3 * * *   $ROOT/scripts/cron_hotpot.sh score-security >> $LOG/score-security.log 2>&1

# Daily 03:30 UTC: snapshot the DB to backups/ (cheap, ~2 MB).
30 3 * * *   $ROOT/scripts/cron_hotpot.sh backup >> $LOG/backup.log 2>&1
